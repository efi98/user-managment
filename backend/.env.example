# Server Configuration
PORT=1000
NODE_ENV=development

# CORS
ALLOWED_ORIGIN=http://localhost:4001

# Session Configuration
COOKIE_NAME=sessionId
SESSION_SECRET=your-secret-key-here
# MAX_AGE_MS controls session cookie lifetime in milliseconds (default 3600000 = 1 hour)
MAX_AGE_MS=3600000

# Redis/Valkey Configuration (optional)
USE_REDIS_SESSION=false
VALKEY_HOST=localhost
VALKEY_PORT=6379

# Database Configuration
DB_PATH=assets/userdb.sqlite

# File Upload Configuration
AVATARS_DIR=assets/uploads/avatars
